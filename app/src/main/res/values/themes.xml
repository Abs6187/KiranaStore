<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base app theme: Material Design 3, light mode -->
    <style name="Theme.KiranaStore" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorOnPrimary">@color/on_accent</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="colorError">@color/color_error</item>
    </style>

    <!-- BottomSheet style override -->
    <style name="ThemeOverlay.KiranaStore.BottomSheet" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/KiranaBottomSheet</item>
    </style>

    <style name="KiranaBottomSheet" parent="Widget.Material3.BottomSheet.Modal">
        <item name="shapeAppearance">@style/KiranaBottomSheetShape</item>
    </style>

    <style name="KiranaBottomSheetShape" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
    </style>

</resources>
